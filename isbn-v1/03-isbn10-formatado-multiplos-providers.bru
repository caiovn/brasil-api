meta {
  name: 03 - ISBN10 formatado com multiplos providers
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/isbn/v1/85-4570-287-X?providers=cbl,google-books
  body: none
  auth: none
}

tests {
  test("retorna sucesso para ISBN10 formatado", function() {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody()).to.have.property("isbn");
  });
}
